# shot2issue configuration (copy to .env and fill in placeholders).
# NEVER commit a real .env — it is gitignored. Keys are read from the
# environment at runtime; nothing here is ever hardcoded into the tool.

# --- Backend selection (optional) -------------------------------------------
# Force a specific vision backend. One of: mock | anthropic | openai.
# If unset, shot2issue auto-detects from whichever API key is present.
# SHOT2ISSUE_BACKEND=anthropic

# Override the model id used by the active backend (optional).
# SHOT2ISSUE_MODEL=claude-3-5-sonnet-latest

# --- Provider keys (set exactly one; placeholders only) ---------------------
# Anthropic (Claude vision):
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# OpenAI (GPT vision):
# OPENAI_API_KEY=sk-REPLACE_ME
